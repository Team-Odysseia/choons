# PostgreSQL
POSTGRES_URI=jdbc:postgresql://localhost:5432/choons
POSTGRES_USER=choons
POSTGRES_PASS=change_me

# Cloudflare R2 (or S3-compatible)
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY=your_access_key
R2_SECRET_KEY=your_secret_key

# JWT signing secret — MUST be a strong random string (min 256 bits)
JWT_SECRET=generate_a_strong_random_secret_here

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Auth cookie security
AUTH_COOKIE_NAME=CHOONS_AUTH
AUTH_COOKIE_SECURE=false
